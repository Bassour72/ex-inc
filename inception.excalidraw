    {
      "id": "oCROM1JwLS9Akdgdu1lcH",
      "type": "text",
      "x": 908.6652526855469,
      "y": 6662.64453125,
      "width": 386.07965087890625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3C",
      "roundness": null,
      "seed": 1469047378,
      "version": 469,
      "versionNonce": 754565394,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772591393453,
      "link": null,
      "locked": false,
      "text": "How does this happen? Docker uses a\nLinux feature called Namespaces to\nisolate the container. This controls\nwhat the container can 'see.' When you\ncreate a container, the first process\nyou run inside it—whether it is Bash or\na Python script—is assigned PID 1.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "mm2NJGAHy062_4kwnPg5F",
      "originalText": "How does this happen? Docker uses a Linux feature called Namespaces to isolate the container. This controls what the container can 'see.' When you create a container, the first process you run inside it—whether it is Bash or a Python script—is assigned PID 1.",
      "autoResize": true,
      "lineHeight": 1.25
    },
