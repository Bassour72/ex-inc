      "x": 980.3589477539062,
      "y": 6241.36328125,
      "width": 276.8797607421875,
      "height": 200,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b34V",
      "roundness": null,
      "seed": 1622000846,
      "version": 585,
      "versionNonce": 1196394830,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772591009627,
      "link": null,
      "locked": false,
      "text": "Note: Inside the container,\nyour process always takes\nPID 1. However, on the host\n(the outside), it is assigned\na different number, like\n5000, because the host\nsees it as just another\nprocess.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "o4rQ7JSNLhua4Qe7Vi6-4",
      "originalText": "Note: Inside the container, your process always takes PID 1. However, on the host (the outside), it is assigned a different number, like 5000, because the host sees it as just another process.",
      "autoResize": true,
      "lineHeight": 1.25
    },
