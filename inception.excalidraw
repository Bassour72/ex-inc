    {
      "id": "OR9gGcR02uwrKmUf56Ff8",
      "type": "rectangle",
      "x": 512.3359375,
      "y": 7065.59375,
      "width": 319.46484375,
      "height": 235,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
