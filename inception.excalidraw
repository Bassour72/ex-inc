      "locked": false
    },
    {
      "id": "L50hIhjcPVYbhfAScdxqH",
      "type": "text",
      "x": 519.4085083007812,
      "y": 7070.59375,
      "width": 305.3197021484375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3I",
      "roundness": null,
      "seed": 1757891726,
      "version": 355,
      "versionNonce": 643619218,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772591608041,
      "link": null,
      "locked": false,
      "text": "Namespaces are a Linux kernel\nfeature that isolates system\nresources for a group of\nprocesses. It ensures that one\nset of processes can only see\nand interact with its own\nresources, while remaining\ncompletely unaware of\nresources in other namespaces.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "OR9gGcR02uwrKmUf56Ff8",
      "originalText": "Namespaces are a Linux kernel feature that isolates system resources for a group of processes. It ensures that one set of processes can only see and interact with its own resources, while remaining completely unaware of resources in other namespaces.",
      "autoResize": true,
      "lineHeight": 1.25
    },
