      "locked": false,
      "text": "A container is a lightweight,\nstandalone, and executable\npackage that includes everything\nneeded to run an\napplication—code, runtime,\nsystem tools, libraries, and\nsettings.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "L77KwD-iFbGh0Nth1CbL4",
      "originalText": "A container is a lightweight, standalone, and executable package that includes everything needed to run an application—code, runtime, system tools, libraries, and settings.",
      "autoResize": true,
      "lineHeight": 1.25
    },
