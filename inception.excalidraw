    },
    {
      "id": "uXLD6bF_oahRZUGzPo_zq",
      "type": "text",
      "x": 976.8518295288086,
      "y": 7622.70703125,
      "width": 224.3197784423828,
      "height": 175,
      "angle": 0,
      "strokeColor": "#ffa94d",
      "backgroundColor": "#0c8599",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "bYEh1WcB4ozVCeh2jx1mZ"
      ],
      "frameId": null,
      "index": "b3d",
      "roundness": null,
      "seed": 1693674638,
      "version": 323,
      "versionNonce": 1599518222,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772592040040,
      "link": null,
      "locked": false,
      "text": "UTS Namespace: You\ncan give the container\nits own hostname (like\nmy-python-app) that is\ndifferent from your\ncomputer's name.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "INGbhJLkx4OeohGjhBETh",
      "originalText": "UTS Namespace: You can give the container its own hostname (like my-python-app) that is different from your computer's name.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Yq7kFuACt0fmZMkPSQuj6",
      "type": "rectangle",
      "x": 377.42578125,
      "y": 7988.296875,
      "width": 648.4296874999999,
      "height": 486.8085937500001,
      "angle": 0,
      "strokeColor": "#eaddd7",
      "backgroundColor": "#c2255c",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3e",
      "roundness": {
        "type": 3
      },
      "seed": 157788690,
      "version": 238,
      "versionNonce": 1081192658,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "jl1EnXLkUuXdqvLn7s2CI"
        }
      ],
      "updated": 1772592513756,
      "link": null,
      "locked": false
    },
    {
      "id": "jl1EnXLkUuXdqvLn7s2CI",
      "type": "text",
      "x": 392.7909240722656,
      "y": 8081.701171875,
      "width": 617.6994018554688,
      "height": 300,
      "angle": 0,
      "strokeColor": "#eaddd7",
      "backgroundColor": "#c2255c",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3f",
      "roundness": null,
      "seed": 233757390,
      "version": 126,
      "versionNonce": 342345362,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772592513756,
      "link": null,
      "locked": false,
      "text": "PID (Process ID): Gives the container its own process tree,\nallowing the first process to be PID 1.\nNET (Network): Provides a private network stack, including its\nown IP addresses, routing tables, and firewall rules.\nMNT (Mount): Isolates the filesystem, so the container only\nsees the folders it is allowed to access.\nUTS (Unix Time-Sharing): Allows the container to have its own\nunique hostname and domain name.\nUSER: Maps user IDs inside the container to different IDs on\nthe host (e.g., being \"root\" inside but a \"normal user\" outside).\nIPC (Inter-Process Communication): Isolates communication\nchannels like shared memory and message queues.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Yq7kFuACt0fmZMkPSQuj6",
      "originalText": "PID (Process ID): Gives the container its own process tree, allowing the first process to be PID 1.\nNET (Network): Provides a private network stack, including its own IP addresses, routing tables, and firewall rules.\nMNT (Mount): Isolates the filesystem, so the container only sees the folders it is allowed to access.\nUTS (Unix Time-Sharing): Allows the container to have its own unique hostname and domain name.\nUSER: Maps user IDs inside the container to different IDs on the host (e.g., being \"root\" inside but a \"normal user\" outside).\nIPC (Inter-Process Communication): Isolates communication channels like shared memory and message queues.",
      "autoResize": true,
      "lineHeight": 1.25
    },
